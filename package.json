{
  "name": "project-fairly-html-transcripts",
  "version": "3.2.1",
  "description": "A nicely formatted html transcript generator for seyfert.",
  "main": "dist/index.js",
  "homepage": "https://github.com/Ganyu-Studios/project-fairly-html-transcripts",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "lint": "prettier --write --cache . && eslint --cache --fix .",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "vite": "vite",
    "test:seyfert": "tsx ./tests/seyfert-generate.ts",
    "test:djs": "tsx ./tests/djs-generate.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ganyu-Studios/project-fairly-html-transcripts.git"
  },
  "keywords": [
    "seyfert",
    "seyfert-transcripts",
    "seyfert-html-transcripts",
    "html-transcripts",
    "seyfert-html-transcripts",
    "discord-transcripts"
  ],
  "author": "Derock <derock@derock.dev>",
  "license": "GNU GPLv3",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.37.0",
    "@penwin/discord-components-core": "^4.3.5",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.1",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "sharp": "^0.34.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  },
  "dependencies": {
    "@derockdev/discord-components-core": "^3.6.1",
    "@derockdev/discord-components-react": "^3.6.1",
    "@penwin/discord-components-react-render": "^4.3.5",
    "discord-api-types": "^0.38.29",
    "discord-markdown-parser": "~1.2.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "simple-markdown": "^0.7.3",
    "twemoji": "^14.0.2",
    "undici": "^7.16.0"
  },
  "peerDependencies": {
    "discord.js": "^14.22.1",
    "seyfert": "3.2.7-dev-18148457259.0"
  },
  "overrides": {
    "react": "$react"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.18.1+sha512.77a884a165cbba2d8d1c19e3b4880eee6d2fcabd0d879121e282196b80042351d5eb3ca0935fa599da1dc51265cc68816ad2bddd2a2de5ea9fdf92adbec7cd34"
}
