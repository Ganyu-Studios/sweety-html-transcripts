{
  "name": "project-fairly-html-transcripts",
  "version": "3.2.1",
  "description": "A nicely formatted html transcript generator for seyfert.",
  "main": "dist/index.js",
  "homepage": "https://github.com/Ganyu-Studios/project-fairly-html-transcripts",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "lint": "prettier --write --cache . && eslint --cache --fix .",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "vite": "vite",
    "test:seyfert": "tsx ./tests/seyfert-generate.ts",
    "test:djs": "tsx ./tests/djs-generate.ts",
    "update-components": "pnpm update @penwin/*@latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ganyu-Studios/project-fairly-html-transcripts.git"
  },
  "keywords": [
    "seyfert",
    "seyfert-transcripts",
    "seyfert-html-transcripts",
    "html-transcripts",
    "seyfert-html-transcripts",
    "discord-transcripts"
  ],
  "author": "Derock <derock@derock.dev>",
  "license": "GNU GPLv3",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map"
  ],
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@penwin/discord-components-core": "^4.3.8",
    "@types/debug": "^4.1.12",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@derockdev/discord-components-core": "^3.6.1",
    "@derockdev/discord-components-react": "^3.6.1",
    "@penwin/discord-components-react-render": "^4.3.8",
    "discord-api-types": "^0.38.37",
    "discord-markdown-parser": "~1.3.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "simple-markdown": "^0.7.3",
    "twemoji": "^14.0.2",
    "undici": "^7.16.0"
  },
  "peerDependencies": {
    "discord.js": "^14.22.1",
    "seyfert": "3.2.7-dev-18148457259.0"
  },
  "overrides": {
    "react": "$react"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.26.1+sha512.664074abc367d2c9324fdc18037097ce0a8f126034160f709928e9e9f95d98714347044e5c3164d65bd5da6c59c6be362b107546292a8eecb7999196e5ce58fa"
}
