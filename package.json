{
  "name": "sweety-html-transcripts",
  "version": "0.2.5",
  "description": "A sweety formatted html transcript generator for discord bots.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "homepage": "https://github.com/Ganyu-Studios/sweety-html-transcripts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "prepare": "husky",
    "lint": "prettier --write --cache . && eslint --cache --fix .",
    "typecheck": "tsc -p tsconfig.eslint.json",
    "vite": "vite",
    "test:seyfert": "tsx ./tests/seyfert-generate.ts",
    "test:djs": "tsx ./tests/djs-generate.ts",
    "update-components": "pnpm update @penwin/*@latest"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/*": {
      "import": "./dist/adapters/*.js",
      "require": "./dist/adapters/*.js",
      "types": "./dist/adapters/*.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ganyu-Studios/sweety-html-transcripts.git"
  },
  "keywords": [
    "seyfert",
    "discord.js",
    "seyfert-transcripts",
    "discordjs-transcripts",
    "sweety-html-transcripts",
    "html-transcripts",
    "discord-transcripts"
  ],
  "author": "Ganyu Studios",
  "license": "GNU GPLv3",
  "contributors": [
    {
      "name": "JustEvil",
      "url": "https://github.com/EvilG-MC"
    }
  ],
  "files": [
    "dist/**"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@penwin/discord-components-core": "^4.3.8",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "seyfert": "4.3.0",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@derockdev/discord-components-core": "^3.6.1",
    "@penwin/discord-components-react-render": "^4.3.8",
    "discord-api-types": "^0.38.47",
    "discord-markdown-parser": "~1.3.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "simple-markdown": "^0.7.3",
    "twemoji": "^14.0.2"
  },
  "peerDependencies": {
    "discord.js": "^14.25.1",
    "seyfert": "4.2.2"
  },
  "overrides": {
    "react": "$react"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
